import { Team } from '@/components/sections/team';
import { Footer } from '@/components/sections/footer';

export default function Home() {
  const lang = 'EN';
  const c = content[lang as keyof typeof content];

  const navLinks = [
    { label: 'SERVICES', href: '#services' },
    { label: 'WORK', href: '#work' },
    { label: 'TEAM', href: '#team' },
    { label: 'CONTACT', href: '#contact' },
  ];

  const socialLinks = [
    { icon: Mail, href: 'mailto:hello@heydestudio.ai' },
    { icon: ExternalLink, href: 'https://instagram.com/heyde.studio' },
    { icon: Link, href: 'https://linkedin.com' },
  ];

  return (
    <main className="bg-white">
      {/* 1. HERO */}
      <MinimalistHero
        logoText="HEYDE"
        navLinks={navLinks}
        headline={c.hero.headline}
        subheadline={c.hero.subheadline}
        body={c.hero.body}
        ctaPrimary={c.hero.ctaPrimary}
        ctaPrimaryLink="#contact"
        ctaSecondary={c.hero.ctaSecondary}
        ctaSecondaryLink={c.hero.ctaSecondaryLink}
        imageSrc="/images/s3-solea.jpg"
        imageAlt="HEYDE Studio - Visual Systems"
        overlayText={{
          part1: 'Visual',
          part2: 'Systems.',
        }}
        socialLinks={socialLinks}
        locationText="Madrid, Spain"
      />

      {/* 2. VALUE PROPOSITION */}
      <section className="min-h-screen bg-black text-white px-8 py-16 md:px-12 md:py-24">
        <div className="max-w-6xl mx-auto">
          <h2 className="text-4xl md:text-5xl font-bold mb-12 text-center">{c.valueProposition.heading}</h2>
          <div className="text-lg leading-relaxed max-w-3xl mx-auto text-center mb-20 whitespace-pre-wrap">
            {c.valueProposition.mainCopy.split('\n').map((line, i, arr) => (
              <React.Fragment key={i}>
                {line}
                {i < arr.length - 1 && <br />}
              </React.Fragment>
            ))}
          </div>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
            {c.valueProposition.pillars.map((pillar, i) => (
              <div key={i} className="border border-white/20 p-6 rounded">
                <h3 className="text-xl font-bold mb-3">{pillar.title}</h3>
                <p className="text-white/80 whitespace-pre-wrap">
                  {pillar.description.split('\n').map((line, j, arr) => (
                    <React.Fragment key={j}>
                      {line}
                      {j < arr.length - 1 && <br />}
                    </React.Fragment>
                  ))}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 3. PROBLEM → SOLUTION */}
      {/* <ProblemSolution
        heading={c.problemSolution.heading}
        painPoints={c.problemSolution.painPoints}
        solution={c.problemSolution.solution}
      /> */}

      {/* 4. SERVICES */}
      <section id="services" className="min-h-screen bg-white px-8 py-16 md:px-12 md:py-24">
        <div className="max-w-6xl mx-auto">
          <h2 className="text-4xl md:text-5xl font-bold mb-16 text-center">{c.services.heading}</h2>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
            {c.services.lines.map((line, i) => (
              <div key={i} className="border border-gray-200 p-8 rounded">
                <div className="text-5xl font-bold text-gray-200 mb-4">{line.number}</div>
                <h3 className="text-2xl font-bold mb-4">{line.title}</h3>
                <p className="text-gray-700 mb-6 whitespace-pre-wrap">
                  {line.description.split('\n').map((lineText, j, arr) => (
                    <React.Fragment key={j}>
                      {lineText}
                      {j < arr.length - 1 && <br />}
                    </React.Fragment>
                  ))}
                </p>
                <div className="mb-6">
                  <h4 className="font-bold mb-2">Includes:</h4>
                  <ul className="space-y-1">
                    {line.includes.map((item, j) => (
                      <li key={j} className="text-sm text-gray-600">• {item}</li>
                    ))}
