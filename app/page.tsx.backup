                </div>
                <div className="border-t pt-4">
                  <p className="font-bold mb-2">{line.price}</p>
                  <a href="#contact" className="text-sm font-medium text-black underline hover:opacity-70">
                    {line.cta}
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 5. WHY US */}
      {/* <WhyUs */}
        heading={c.whyUs.heading}
        subheading={c.whyUs.subheading}
