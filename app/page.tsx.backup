      />

      {/* 9. FAQ */}
      <FAQ
        heading={c.faq.heading}
        questions={c.faq.questions}
      />

      {/* 10. FINAL CTA */}
      <FinalCTA
        heading={c.finalCTA.heading}
        subheading={c.finalCTA.subheading}
        copy={c.finalCTA.copy}
        ctaSchedule={c.finalCTA.ctaSchedule}
        ctaDemo={c.finalCTA.ctaDemo}
      />

      {/* 10.5. TEAM */}
      <Team
        heading={c.team.heading}
        subheading={c.team.subheading}
        members={c.team.members}
      />

      {/* 11. CONTACT */}
      <section id="contact" className="min-h-screen bg-black text-white px-8 py-16 md:px-12 md:py-24 flex items-center">
        <div className="max-w-2xl mx-auto w-full text-center">
          <h2 className="text-4xl md:text-5xl font-bold mb-4">{c.contact.heading}</h2>
          <p className="text-white/60 mb-12">{c.contact.subheading}</p>

          <div className="space-y-6">
            <div>
              <p className="text-white/60 mb-2">Email</p>
              <a href={`mailto:${c.contact.email}`} className="text-2xl font-bold underline hover:opacity-70">
                {c.contact.email}
              </a>
            </div>

            <div>
              <p className="text-white/60 mb-2">WhatsApp</p>
              <a href={`https://wa.me/34671141135`} className="text-2xl font-bold underline hover:opacity-70">
                {c.contact.phone}
              </a>
            </div>

            <div className="border-t border-white/20 pt-8 mt-8">
              <p className="text-white/60 mb-4">Social</p>
              <div className="flex justify-center gap-6">
                <a href="https://instagram.com/heyde.studio" className="font-bold underline hover:opacity-70">
                  Instagram
                </a>
                <a href="https://linkedin.com" className="font-bold underline hover:opacity-70">
                  LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* 12. FOOTER */}
      <Footer
