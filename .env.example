# Public site configuration
NEXT_PUBLIC_SITE_URL=https://heydestudio.com
NEXT_PUBLIC_APP_URL=https://heydestudio.com

# Internal API protection
INTERNAL_API_TOKEN=replace-with-a-long-random-secret

# Calendly webhook protection
CALENDLY_WEBHOOK_TOKEN=replace-with-a-long-random-secret

# Email provider: Brevo
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_EMAIL=contact@heydestudio.com

# CRM provider: HubSpot
HUBSPOT_ACCESS_TOKEN=replace-with-hubspot-private-app-token
HUBSPOT_DEAL_PIPELINE=default
# Backwards-compatible fallback if already set in Vercel/local envs:
# HUBSPOT_API_KEY=replace-with-hubspot-private-app-token

# Analytics
NEXT_PUBLIC_GA_ID=G-X5ZD3ZGJ1Q
